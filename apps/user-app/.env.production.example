# Copy to apps/user-app/.env.production and replace each REPLACE_* value
# before building the production AAB. These keys are read by Expo at bundle
# time and baked into the APK / AAB — they cannot be changed without rebuilding.

# Public URL of the api-server (Fastify, port 4000 in dev).
EXPO_PUBLIC_API_BASE_URL=https://REPLACE_WITH_PROD_API_HOST

# Public URL of the socket-server (socket.io, port 4001 in dev). Must be
# wss:// in production for TLS — never plain ws://.
EXPO_PUBLIC_SOCKET_BASE_URL=wss://REPLACE_WITH_PROD_SOCKET_HOST

# Hosted privacy policy URL — Play Store listing also needs this exact value.
# We host it on the admin-web Vercel deployment at the /privacy path.
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://REPLACE_WITH_ADMIN_DOMAIN/privacy
