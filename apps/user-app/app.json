{
  "expo": {
    "name": "Jeevan Rakshak",
    "slug": "jr-user-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "jruser",
    "userInterfaceStyle": "light",
    "platforms": ["android", "web"],
    "jsEngine": "hermes",
    "newArchEnabled": false,
    "web": {
      "bundler": "metro"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#E5322B",
      "resizeMode": "contain"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/REPLACE_USER_EAS_PROJECT_ID"
    },
    "android": {
      "package": "com.jeevanrakshak.user",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E5322B"
      }
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_USER_EAS_PROJECT_ID"
      }
    }
  }
}
