# Copy to apps/driver-app/.env.production and replace each REPLACE_* value
# before building the production AAB. These keys are baked into the AAB at
# build time — they cannot be changed without rebuilding.

EXPO_PUBLIC_API_BASE_URL=https://REPLACE_WITH_PROD_API_HOST
EXPO_PUBLIC_SOCKET_BASE_URL=wss://REPLACE_WITH_PROD_SOCKET_HOST
EXPO_PUBLIC_PRIVACY_POLICY_URL=https://jr-admin.vercel.app/privacy
