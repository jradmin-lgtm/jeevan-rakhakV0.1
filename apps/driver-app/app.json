{
  "expo": {
    "name": "Jeevan Rakshak Driver",
    "slug": "jr-driver-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "jrdriver",
    "userInterfaceStyle": "light",
    "platforms": [
      "android",
      "web"
    ],
    "jsEngine": "hermes",
    "newArchEnabled": false,
    "web": {
      "bundler": "metro"
    },
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "backgroundColor": "#0F172A",
      "resizeMode": "contain"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "owner": "jradmin29s-organization",
    "updates": {
      "url": ""
    },
    "android": {
      "package": "com.jeevanrakshak.driver",
      "versionCode": 10,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "POST_NOTIFICATIONS",
        "FOREGROUND_SERVICE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      }
    },
    "extra": {
      "eas": {
        "projectId": "a39978e4-b46f-47bc-9ca8-28deee237fb7"
      }
    }
  }
}