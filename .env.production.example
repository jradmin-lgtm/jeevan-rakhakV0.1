# ─────────────────────────────────────────────────────────────────────────
# Jeevan Rakshak — backend production env (api-server, socket-server,
# worker-jobs, admin-web).
#
# Copy this file's contents into your hosting platform's secret manager
# (Render / Fly / Railway / Cloud Run / Vercel). DO NOT commit a real
# `.env.production` with secret values — this template is the only file
# in this family that the .gitignore allows in git.
#
# Pilot launch values are inline-commented as `# pilot:`. Real-launch values
# replace `# real:`.
# ─────────────────────────────────────────────────────────────────────────

# ── Core ──
NODE_ENV=production

# Generate with:  openssl rand -hex 48
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
JWT_ISSUER=jeevan-rakshak
JWT_ACCESS_TTL_SEC=2592000

# Managed Postgres connection string. Neon / Supabase / RDS / etc.
DATABASE_URL=postgres://REPLACE_USER:REPLACE_PASS@REPLACE_HOST:5432/jr_v0

# Generate two distinct secrets:
INTERNAL_API_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX
ADMIN_API_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Comma-separated list of allowed browser origins. The boot guard refuses
# to start the api-server in production if this is "*".
CORS_ALLOWED_ORIGINS=https://REPLACE_ADMIN_DOMAIN

# Ports (most hosts set $PORT automatically; these defaults are fine).
API_PORT=4000
SOCKET_PORT=4001
API_BASE_URL=https://REPLACE_WITH_PROD_API_HOST
SOCKET_BASE_URL=https://REPLACE_WITH_PROD_SOCKET_HOST

# Rate limits — per IP.
RATE_LIMIT_OTP_PER_MIN=5
RATE_LIMIT_VERIFY_PER_MIN=10
RATE_LIMIT_GENERIC_PER_MIN=120
OTP_MAX_FAILED_ATTEMPTS=5

# Booking economics.
BASE_FARE_INR=500
PER_KM_FARE_INR=30
BOOKING_TIMEOUT_SEC=90

# ── Provider switches ──
# Leave each at `mock` for the pilot. Flip to the real provider name and
# fill in the corresponding keys for the public launch.

SMS_PROVIDER=mock                       # pilot: mock     real: msg91 | twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER=

MAPS_PROVIDER=mock                      # pilot: mock     real: googlemaps | mapbox
GOOGLE_MAPS_API_KEY=
MAPBOX_ACCESS_TOKEN=

PAYMENTS_PROVIDER=mock                  # pilot: mock     real: razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

PUSH_PROVIDER=mock                      # pilot: mock     real: fcm
FCM_SERVER_KEY=

# ── Feature flags ──
FLAG_REQUIRE_KYC=false                  # pilot: false    real: true
FLAG_ENABLE_PAYMENTS=false              # pilot: false    real: true
FLAG_ENABLE_PUSH=false                  # pilot: false    real: true

# DEMO_BYPASS: returns the OTP in the login API response. Pilot only.
# Boot guard rejects this in production.
FLAG_DEMO_BYPASS=false                  # pilot: false    real: false

# PILOT_BYPASS_OTP: makes OTP = last 4 digits of phone (no SMS sent).
# Pilot only — boot guard rejects this in production.
# Set this to `true` ONLY when NODE_ENV is not "production" (e.g. staging,
# closed-pilot environments where you don't want the prod hardening).
FLAG_PILOT_BYPASS_OTP=false             # pilot: true (staging) / false (prod)

# ── Admin-web (Vercel) ──
# Vercel injects these as build-time env. Set them in the Vercel project
# settings (NEVER commit a real value):
NEXT_PUBLIC_API_BASE_URL=https://REPLACE_WITH_PROD_API_HOST
NEXT_PUBLIC_ADMIN_API_KEY=REPLACE_SAME_AS_ADMIN_API_KEY
