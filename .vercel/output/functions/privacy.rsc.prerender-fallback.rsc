16:["$","style",null,{"children":"\n        .privacy {\n          max-width: 760px;\n          margin: 0 auto;\n          padding: 32px 24px 64px;\n          color: #0F172A;\n          line-height: 1.65;\n          font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif;\n        }\n        .privacy h1 { font-size: 32px; margin: 0 0 4px; }\n        .privacy h2 { font-size: 20px; margin: 32px 0 8px; border-top: 1px solid #E2E8F0; padding-top: 24px; }\n        .privacy h3 { font-size: 16px; margin: 20px 0 6px; color: #334155; }\n        .privacy ul { padding-left: 22px; }\n        .privacy li { margin: 6px 0; }\n        .privacy a { color: #E5322B; text-decoration: underline; }\n        .privacy code { background: #F1F5F9; padding: 1px 6px; border-radius: 4px; font-size: 13px; }\n        .privacy .meta { color: #64748B; font-size: 14px; margin: 4px 0 0; }\n        .privacy header { margin-bottom: 16px; }\n        .privacy footer { margin-top: 40px; border-top: 1px solid #E2E8F0; padding-top: 16px; }\n      "}]
