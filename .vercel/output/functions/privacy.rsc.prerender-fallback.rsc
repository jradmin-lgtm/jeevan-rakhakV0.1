",null,{"children":"We only collect what we need to dispatch an ambulance to you safely."}],["$","h3",null,{"children":"From patients (Jeevan Rakshak user app)"}],["$","ul",null,{"children":[["$","li",null,{"children":[["$","strong",null,{"children":"Phone number"}]," — used as your account identifier and for OTP-based sign-in. During the current pilot phase, sign-in is simplified to verify ownership of your phone without sending an SMS; once the pilot ends we move to SMS-delivered OTPs."]}],["$","li",null,{"children":[["$","strong",null,{"children":"Name, blood group, allergies, age, gender"}]," — entered voluntarily in your medical profile so first responders have it during an emergency."]}],"$L4","$L5","$L6","$L7"]}],"$L8","$L9","$La","$Lb"]}],"$Lc","$Ld","$Le","$Lf","$L10","$L11","$L12","$L13","$L14","$L15","$L16"]}],null,"$L17"]}],{},null,false]},null,false]},null,false],"$L18",false]],"m":"$undefined","G":["$19",[]],"s":false,"S":true}
